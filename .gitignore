.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# oh-my-openagents
.sisyphus/*
!.sisyphus/notepads

# Env
.env
.env.local
.env.*.local
!/.env.example
!apps/*/.env.example

# Sisyphus evidence
.sisyphus/evidence/

# Drizzle (keep SQL files tracked, ignore local journal meta)
apps/*/drizzle/meta/

# Playwright per-workspace artifact dirs
e2e/*/test-results/
e2e/*/playwright-report/
e2e/*/playwright/.cache/

# lefthook — per-machine overrides (not committed)
lefthook-local.yml
