# Neon PostgreSQL — pooled connection for app runtime (PgBouncer-compatible)
DATABASE_URL="postgres://USER:PASSWORD@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Neon PostgreSQL — direct connection for migrations (drizzle-kit)
DATABASE_URL_DIRECT="postgres://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# better-auth — generate with: openssl rand -base64 48 | tr -d '\n' | head -c 48
BETTER_AUTH_SECRET="replace-with-48-char-random-secret"

# better-auth — base URL for callbacks (dev: http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"
