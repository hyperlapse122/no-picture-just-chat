{
  "prettier": {
    "allowed": true
  },
  "format_on_save": "on",
  "lsp": {
    "eslint": {}
  },
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  }
}
